# Path to the shared SQLite database used by the desktop app.
# Example on Windows:
# DATA_PATH=C:/Users/ASUS/duant3/ClassSign_MacOS/src/infrastructure/database/database.sqlite
DATA_PATH=YOUR_DATABASE_PATH

# Laptop Wi-Fi IPv4 address for Expo Go on a real iPhone.
# On Windows, run: ipconfig
# On MacOS: ifconfig | grep "inet " | grep -v 127.0.0.1
# Use the IPv4 Address under "Wireless LAN adapter Wi-Fi".
EXPO_PUBLIC_SERVER_IP=YOUR_WIFI_IP
EXPO_PUBLIC_SERVER_PORT=3001
